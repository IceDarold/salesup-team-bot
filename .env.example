TELEGRAM_BOT_TOKEN=123456:replace_me

# Optional: enables large Telegram file downloads via a local Bot API server.
# Start docker-compose.bot-api.yaml and set this to http://127.0.0.1:8081
TELEGRAM_BOT_API_BASE_URL=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

DEEPGRAM_API_KEY=replace_me
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=ru
DEEPGRAM_TIMEOUT=900
VIDEO_EXTRACT_TIMEOUT=1800

INSIGHTS_API_KEY=replace_me
INSIGHTS_BASE_URL=https://apinet.cloud/v1
INSIGHTS_MODEL=claude-opus-4-8-max
INSIGHTS_TIMEOUT=180
INSIGHTS_MAX_TOKENS=8000
INSIGHTS_PROGRESS_INTERVAL=45
REPORT_MODEL=claude-opus-4-6
REPORT_MAX_TOKENS=4500
DEDUPE_MODEL=gpt-4.1-mini
DEDUPE_AUTO_MERGE_THRESHOLD=0.92

TELEGRAPH_SHORT_NAME=Aich
TELEGRAPH_AUTHOR_NAME=Aich Team
TELEGRAPH_ACCESS_TOKEN=
TELEGRAPH_MAX_RETRIES=3
TELEGRAPH_RETRY_BACKOFF_SECONDS=1.5

GOOGLE_DOC_ID=replace_me
GOOGLE_APPLICATION_CREDENTIALS=.secrets/google-credentials.json
GOOGLE_OAUTH_CLIENT_SECRET=.secrets/google-oauth-client.json
GOOGLE_OAUTH_TOKEN=.secrets/google-oauth-token.json
GOOGLE_API_MAX_RETRIES=3
GOOGLE_API_RETRY_BACKOFF_SECONDS=1.5
GOOGLE_TRANSCRIPT_FOLDER_ID=
# For /transcript-created standalone Google Docs: reader, commenter, or writer.
TRANSCRIPT_DOC_PERMISSION=reader

MAX_TELEGRAM_DOWNLOAD_MB=20
MAX_URL_DOWNLOAD_MB=500
URL_DOWNLOAD_TIMEOUT=300
TELEGRAM_READ_TIMEOUT=600
TELEGRAM_WRITE_TIMEOUT=600
TELEGRAM_FILE_TIMEOUT=1800
INTERVIEWS_PAGE_SIZE=8
ACCESS_CACHE_TTL_SECONDS=300
BOT_SETTINGS_PATH=data/settings.json
SUMMARY_CHAT_ID=

BOT_ADMIN_IDS=
BOT_ADMIN_USERNAMES=

NOTION_TOKEN=
NOTION_AICH_MAIN_PAGE_ID=
NOTION_TEAM_MEMBERS_DB_ID=
NOTION_INTERVIEWS_DB_ID=
NOTION_JTBD_DB_ID=
NOTION_PAINS_DB_ID=
NOTION_BARRIERS_DB_ID=
NOTION_WTP_DB_ID=
NOTION_OPPORTUNITIES_DB_ID=
