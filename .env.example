TELEGRAM_BOT_TOKEN=123456:replace_me

# Optional: enables large Telegram file downloads via a local Bot API server.
# Start docker-compose.bot-api.yaml and set this to http://127.0.0.1:8081
TELEGRAM_BOT_API_BASE_URL=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Personal Telegram accounts (QR login via MTProto). Keep this Fernet key secret.
TELEGRAM_SESSION_ENCRYPTION_KEY=
TELEGRAM_USER_DB_PATH=data/telegram-users.sqlite3
# Archive every message in personal chats that can be matched unambiguously to Contacts.
# The user must explicitly enable the archive in the bot after connecting Telegram.
TELEGRAM_ARCHIVE_SYNC_SECONDS=60
# Poll due personal Telegram messages and ask their owner for a final confirmation.
SCHEDULED_MESSAGES_TIMEZONE=Europe/Moscow
SCHEDULED_MESSAGE_CHECK_SECONDS=30
TELEGRAM_ARCHIVE_CONSENT_VERSION=2026-07-12
TELEGRAM_VOICE_TRANSCRIPTION_MAX_MB=25
# Required only for accounts with Telegram 2FA. This public HTTPS URL must proxy
# /telegram/2fa/* to TELEGRAM_2FA_CALLBACK_HOST:TELEGRAM_2FA_CALLBACK_PORT.
TELEGRAM_2FA_WEB_BASE_URL=https://team.salesup.group
TELEGRAM_2FA_CALLBACK_HOST=127.0.0.1
TELEGRAM_2FA_CALLBACK_PORT=8094

DEEPGRAM_API_KEY=replace_me
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=ru
DEEPGRAM_TIMEOUT=900
VIDEO_EXTRACT_TIMEOUT=1800

OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5.6-terra
INSIGHTS_TIMEOUT=180
INSIGHTS_MAX_TOKENS=8000
INSIGHTS_PROGRESS_INTERVAL=45
# LLM review of a contact's conversation after new Telegram messages are synced.
CONTACT_STATUS_MODEL=
CONTACT_STATUS_MAX_TOKENS=700
CONTACT_STATUS_MAX_MESSAGES=500
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# PDF prospect research and personalized outreach drafts.
SALES_RESEARCH_MODEL=gpt-5.6-terra
SALES_ACTION_MODEL=gpt-5.6-terra
COMPANY_RESEARCH_MODEL=gpt-5.6-terra
# Persistent deep-company research queue. Jobs are processed by research_worker.
RESEARCH_JOBS_DB_PATH=data/research-jobs.sqlite3
RESEARCH_WORKER_POLL_SECONDS=5
DEEP_RESEARCH_MAX_MINUTES=20
DEEP_RESEARCH_MAX_SOURCES=40
DEEP_RESEARCH_MAX_ITERATIONS=6
REPORT_MODEL=gpt-5.6-terra
REPORT_MAX_TOKENS=4500
DEDUPE_MODEL=gpt-4.1-mini
DEDUPE_AUTO_MERGE_THRESHOLD=0.92

